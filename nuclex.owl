  <owl:Class rdf:about="http://nuclex.org/ontology/nuclex_000286">
    <rdfs:label>model-based absorbed dose calculation</rdfs:label>
    <nuclex:preferred_name>model-based absorbed dose calculation</nuclex:preferred_name>
    <oio:id>nuclex:000286</oio:id>
    <nuclex:definition>An organ-based absorbed dose calculation that utilizes standardized mathematical representations of human anatomy and pre-calculated source-to-target specific absorbed fractions.</nuclex:definition>
    <nuclex:synonym>model-based dosimetry method</nuclex:synonym>
    <nuclex:nuclex_nid>nuclex:000286</nuclex:nuclex_nid>
