    <nuclex:preferred_name>positron emission tomography response criteria in solid tumors</nuclex:preferred_name>
    <oio:id>nuclex:000627</oio:id>
    <nuclex:definition>Criteria for assessing tumor response to therapy using functional changes on PET scans. It focuses on changes in the metabolic activity (specifically, the peak SUV) of tumors, rather than just changes in size.</nuclex:definition>
    <nuclex:synonym>PERCIST</nuclex:synonym>
    <nuclex:nuclex_nid>nuclex:000627</nuclex:nuclex_nid>
    <nuclex:Other>10.2967/jnumed.108.057307</nuclex:Other>
    <nuclex:Other_axiom>rdfs:seeAlso</nuclex:Other_axiom>
    <rdfs:subClassOf rdf:resource="http://nuclex.org/ontology/nuclex_000619"/>
  </owl:Class>
