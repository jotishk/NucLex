  <owl:Class rdf:about="http://nuclex.org/ontology/nuclex_000651">
    <rdfs:label>lumen diameter</rdfs:label>
    <nuclex:preferred_name>lumen diameter</nuclex:preferred_name>
    <oio:id>nuclex:000651</oio:id>
    <nuclex:definition>The long-axis inner length of a tubular structure, such as a blood vessel, measured on a plane perpendicular to the long-axis of the structure.</nuclex:definition>
    <nuclex:synonym>hollow diameter</nuclex:synonym>
    <nuclex:nuclex_nid>nuclex:000651</nuclex:nuclex_nid>
    <rdfs:subClassOf rdf:resource="http://nuclex.org/ontology/nuclex_000645"/>
  </owl:Class>
  <owl:Class rdf:about="http://nuclex.org/ontology/nuclex_000093">
    <rdfs:label>tau positron emission tomography brain scan</rdfs:label>
    <nuclex:preferred_name>tau positron emission tomography brain scan</nuclex:preferred_name>
    <oio:id>nuclex:000093</oio:id>
    <nuclex:definition>A PET scan that uses a radiolabeled tau protein–binding ligand to visualize and quantify pathological tau aggregate distribution in the brain.</nuclex:definition>
    <nuclex:synonym>tau PET scan</nuclex:synonym>
    <nuclex:synonym>tau scan</nuclex:synonym>
    <nuclex:nuclex_nid>nuclex:000093</nuclex:nuclex_nid>
    <rdfs:subClassOf rdf:resource="http://nuclex.org/ontology/nuclex_000091"/>
  </owl:Class>
  <owl:Class rdf:about="http://nuclex.org/ontology/nuclex_000514">
    <rdfs:label>[90Y]Y-DOTA-TOC</rdfs:label>
    <nuclex:preferred_name>[90Y]Y-DOTA-TOC</nuclex:preferred_name>
    <oio:id>nuclex:000514</oio:id>
    <nuclex:definition>A therapeutic radiopharmaceutical composed of Yttrium-90 chelated to the somatostatin analogue DOTA-TOC.</nuclex:definition>
    <nuclex:synonym>[90Y]Y DOTATOC</nuclex:synonym>
