  <owl:Class rdf:about="http://nuclex.org/ontology/nuclex_000186">
    <rdfs:label>urea breath test</rdfs:label>
    <nuclex:preferred_name>urea breath test</nuclex:preferred_name>
    <oio:id>nuclex:000186</oio:id>
    <nuclex:definition>A nuclear medicine diagnostic test used to identify active Helicobacter pylori infections in the stomach by measuring the amount of radiolabeled carbon dioxide exhaled after the patient ingests urea tagged with a carbon isotope.</nuclex:definition>
    <nuclex:synonym>C-14 urea breath test</nuclex:synonym>
    <nuclex:synonym>H. pylori breath test</nuclex:synonym>
