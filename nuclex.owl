  </owl:Class>
  <owl:Class rdf:about="http://nuclex.org/ontology/nuclex_000087">
    <rdfs:label>brain death scan</rdfs:label>
    <nuclex:preferred_name>brain death scan</nuclex:preferred_name>
    <oio:id>nuclex:000087</oio:id>
