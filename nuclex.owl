  </owl:Class>
  <owl:Class rdf:about="http://nuclex.org/ontology/nuclex_000538">
    <rdfs:label>[131I]MIBG</rdfs:label>
    <nuclex:preferred_name>[131I]MIBG</nuclex:preferred_name>
    <oio:id>nuclex:000538</oio:id>
    <nuclex:definition>A therapeutic radiopharmaceutical that acts as a false neurotransmitter and is taken up by the norepinephrine transporter in neuroendocrine tumors.</nuclex:definition>
