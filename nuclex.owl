  <owl:Class rdf:about="http://nuclex.org/ontology/nuclex_000287">
    <rdfs:label>medical internal dosimetry method</rdfs:label>
    <nuclex:preferred_name>medical internal dosimetry method</nuclex:preferred_name>
    <oio:id>nuclex:000287</oio:id>
    <nuclex:definition>A model-based absorbed dose calculation formalized by the Medical Internal Radiation Dose committee, utilizing the schema of source organs, target organs, and S-values to calculate mean absorbed doses from internally administered radionuclides.</nuclex:definition>
    <nuclex:synonym>MIRD</nuclex:synonym>
    <nuclex:synonym>MIRD method</nuclex:synonym>
    <nuclex:synonym>S-value based dosimetry</nuclex:synonym>
    <nuclex:synonym>MIRD formulism</nuclex:synonym>
    <nuclex:nuclex_nid>nuclex:000287</nuclex:nuclex_nid>
    <rdfs:subClassOf rdf:resource="http://nuclex.org/ontology/nuclex_000286"/>
  </owl:Class>
  <owl:Class rdf:about="http://nuclex.org/ontology/nuclex_000803">
    <rdfs:label>adult reference computational phantom</rdfs:label>
    <nuclex:preferred_name>adult reference computational phantom</nuclex:preferred_name>
    <oio:id>nuclex:000803</oio:id>
    <nuclex:definition>A standardized, high-resolution voxel-based computational phantom officially adopted by the International Commission on Radiological Protection (ICRP), representing the anatomical geometry of the adult Reference Male or Reference Female for uniform dosimetric evaluations.</nuclex:definition>
    <nuclex:synonym>ICRP phantom</nuclex:synonym>
    <nuclex:synonym>ICRP reference phantom</nuclex:synonym>
    <nuclex:synonym>ICRP adult reference computational phantom</nuclex:synonym>
    <nuclex:nuclex_nid>nuclex:000803</nuclex:nuclex_nid>
    <rdfs:subClassOf rdf:resource="http://nuclex.org/ontology/nuclex_000801"/>
  </owl:Class>
  <owl:Class rdf:about="http://nuclex.org/ontology/nuclex_000758">
