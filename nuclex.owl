    <oio:id>nuclex:000199</oio:id>
    <nuclex:definition>A dosimetry process that calculates absorbed doses to organs and tissues following the administration of unsealed radioactive materials.</nuclex:definition>
    <nuclex:synonym>RPT dosimetry</nuclex:synonym>
    <nuclex:synonym>internal dosimetry</nuclex:synonym>
    <nuclex:synonym>radionuclide dosimetry</nuclex:synonym>
    <nuclex:nuclex_nid>nuclex:000199</nuclex:nuclex_nid>
