  </owl:Class>
  <owl:Class rdf:about="http://nuclex.org/ontology/nuclex_000047">
    <rdfs:label>oncologic nuclear medicine scan</rdfs:label>
    <nuclex:preferred_name>oncologic nuclear medicine scan</nuclex:preferred_name>
    <oio:id>nuclex:000047</oio:id>
    <nuclex:definition>A general category of nuclear medicine scans in which the goal is to detect or assess cancer.</nuclex:definition>
    <nuclex:synonym>nuclear medicine oncology scan</nuclex:synonym>
    <nuclex:synonym>nuclear medicine oncology imaging</nuclex:synonym>
    <nuclex:nuclex_nid>nuclex:000047</nuclex:nuclex_nid>
