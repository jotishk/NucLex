    <rdfs:subClassOf rdf:resource="http://nuclex.org/ontology/nuclex_000141"/>
  </owl:Class>
  <owl:Class rdf:about="http://nuclex.org/ontology/nuclex_000721">
    <rdfs:label>morphological feature</rdfs:label>
    <nuclex:preferred_name>morphological feature</nuclex:preferred_name>
    <oio:id>nuclex:000721</oio:id>
    <nuclex:definition>Any metric describing the three-dimensional geometry of a region, independent of its intensity values.</nuclex:definition>
    <nuclex:synonym>shape measurement</nuclex:synonym>
    <nuclex:synonym>morphological measurement</nuclex:synonym>
    <nuclex:nuclex_nid>nuclex:000721</nuclex:nuclex_nid>
