  <owl:Class rdf:about="http://nuclex.org/ontology/nuclex_000802">
    <rdfs:label>radiation dose assessment resource phantom</rdfs:label>
    <nuclex:preferred_name>radiation dose assessment resource phantom</nuclex:preferred_name>
    <oio:id>nuclex:000802</oio:id>
    <nuclex:definition>A computational phantom, encompassing both stylized and voxel-based models, developed by the Radiation Dose Assessment Resource task group to standardize internal and external radiopharmaceutical dosimetry calculations.</nuclex:definition>
    <nuclex:synonym>RADAR phantom</nuclex:synonym>
    <nuclex:nuclex_nid>nuclex:000802</nuclex:nuclex_nid>
