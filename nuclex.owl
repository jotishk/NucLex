  </owl:Class>
  <owl:Class rdf:about="http://nuclex.org/ontology/nuclex_000032">
    <rdfs:label>hybrid imaging procedure</rdfs:label>
    <nuclex:preferred_name>hybrid imaging procedure</nuclex:preferred_name>
    <oio:id>nuclex:000032</oio:id>
    <nuclex:definition>An imaging procedure combining data from two or more different modalities, typically acquired in the same exam.</nuclex:definition>
    <nuclex:synonym>dual-modality imaging</nuclex:synonym>
