  </owl:Class>
  <owl:Class rdf:about="http://nuclex.org/ontology/nuclex_001186">
    <rdfs:label>nuclear medicine imaging device performance property</rdfs:label>
    <nuclex:preferred_name>nuclear medicine imaging device performance property</nuclex:preferred_name>
    <oio:id>nuclex:001186</oio:id>
    <nuclex:definition>A measurement that describes how well a nuclear imaging device performs.</nuclex:definition>
