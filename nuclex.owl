    <nuclex:synonym>transport rate</nuclex:synonym>
    <nuclex:nuclex_nid>nuclex:001217</nuclex:nuclex_nid>
    <rdfs:subClassOf rdf:resource="http://nuclex.org/ontology/nuclex_001212"/>
  </owl:Class>
  <owl:Class rdf:about="http://nuclex.org/ontology/nuclex_000749">
    <rdfs:label>myocardial flow reserve</rdfs:label>
    <nuclex:preferred_name>myocardial flow reserve</nuclex:preferred_name>
    <oio:id>nuclex:000749</oio:id>
    <nuclex:definition>The ratio of myocardial blood flow at peak pharmacological stress to the myocardial blood flow at rest, measuring the vasodilatory capacity of the coronary arteries.</nuclex:definition>
    <nuclex:synonym>MFR</nuclex:synonym>
    <nuclex:nuclex_nid>nuclex:000749</nuclex:nuclex_nid>
    <rdfs:subClassOf rdf:resource="http://nuclex.org/ontology/nuclex_000742"/>
  </owl:Class>
  <owl:Class rdf:about="http://nuclex.org/ontology/nuclex_001211">
    <rdfs:label>Patlak intercept</rdfs:label>
    <nuclex:preferred_name>Patlak intercept</nuclex:preferred_name>
    <oio:id>nuclex:001211</oio:id>
    <nuclex:definition>The y-intercept of the Patlak plot's linear phase, representing the distribution volume of the tracer in the rapidly equilibrating compartment (plasma and reversible tissue).</nuclex:definition>
    <nuclex:synonym>Ve</nuclex:synonym>
    <nuclex:nuclex_nid>nuclex:001211</nuclex:nuclex_nid>
    <rdfs:subClassOf rdf:resource="http://nuclex.org/ontology/nuclex_001209"/>
  </owl:Class>
  <owl:Class rdf:about="http://nuclex.org/ontology/nuclex_000625">
    <rdfs:label>response evaluation criteria in prostate-specific membrane antigen positron emission tomography/computed tomography</rdfs:label>
    <nuclex:preferred_name>response evaluation criteria in prostate-specific membrane antigen positron emission tomography/computed tomography</nuclex:preferred_name>
    <oio:id>nuclex:000625</oio:id>
    <nuclex:definition>Criteria for standardized assessment of tumor response to therapy in prostate cancer using PSMA PET/CT scans. It defines rules for confirming a response or progression based on changes in PSMA-avid tumor burden.</nuclex:definition>
