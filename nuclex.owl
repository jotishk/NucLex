  <owl:Class rdf:about="http://nuclex.org/ontology/nuclex_000812">
    <rdfs:label>A fillable cylindrical container used to ensure quality control for SPECT and PET imaging systems, with testing spatial resolution, contrast, uniformity, and artifacts using inserts like cold rods and spheres.</rdfs:label>
    <nuclex:preferred_name>A fillable cylindrical container used to ensure quality control for SPECT and PET imaging systems, with testing spatial resolution, contrast, uniformity, and artifacts using inserts like cold rods and spheres.</nuclex:preferred_name>
    <oio:id>nuclex:000812</oio:id>
    <nuclex:definition>A nuclear medicine phantom containing one or more empty compartments that can be filled with a radioactive solution.</nuclex:definition>
