  </owl:Class>
  <owl:Class rdf:about="http://nuclex.org/ontology/nuclex_000518">
    <rdfs:label>therapeutic fibroblast activation protein inhibitor targeted beta-emitting radiopharmaceutical</rdfs:label>
    <nuclex:preferred_name>therapeutic fibroblast activation protein inhibitor targeted beta-emitting radiopharmaceutical</nuclex:preferred_name>
    <oio:id>nuclex:000518</oio:id>
    <nuclex:definition>A therapeutic radiopharmaceutical that targets fibroblast activation protein and delivers its cytotoxic effect through the emission of high-energy beta particles.</nuclex:definition>
    <nuclex:synonym>FAPI beta-emitter</nuclex:synonym>
    <nuclex:synonym>FAPI beta emitting radiopharmaceutical</nuclex:synonym>
    <nuclex:synonym>beta-emitting FAPI radioligand</nuclex:synonym>
