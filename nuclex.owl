  </owl:Class>
  <owl:Class rdf:about="http://nuclex.org/ontology/nuclex_000729">
    <rdfs:label>dynamic measurement</rdfs:label>
    <nuclex:preferred_name>dynamic measurement</nuclex:preferred_name>
    <oio:id>nuclex:000729</oio:id>
    <nuclex:definition>A quantitative value that captures the change in imaging signal over time, derived from a series of images acquired at multiple time points</nuclex:definition>
    <nuclex:synonym>multi-frame measurement</nuclex:synonym>
    <nuclex:synonym>dynamic feature</nuclex:synonym>
    <nuclex:synonym>dynamic measurement</nuclex:synonym>
    <nuclex:nuclex_nid>nuclex:000729</nuclex:nuclex_nid>
