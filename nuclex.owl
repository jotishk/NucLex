  <owl:Class rdf:about="http://nuclex.org/ontology/nuclex_000834">
    <rdfs:label>neck phantom</rdfs:label>
    <nuclex:preferred_name>neck phantom</nuclex:preferred_name>
    <oio:id>nuclex:000834</oio:id>
    <nuclex:definition>A solid plastic cylindrical nuclear medicine phantom designed to simulate the scattering and attenuation properties of the human neck, featuring a standardized cavity designed to accommodate a radioactive pill, vial, or bottle used in the quantification of thyroid uptake for a patient.</nuclex:definition>
    <nuclex:synonym>neck thyroid phantom</nuclex:synonym>
    <nuclex:synonym>thyroid quantification phantom</nuclex:synonym>
    <nuclex:synonym>thyroid uptake neck phantom</nuclex:synonym>
    <nuclex:synonym>thyroid neck phantom</nuclex:synonym>
    <nuclex:nuclex_nid>nuclex:000834</nuclex:nuclex_nid>
    <rdfs:subClassOf rdf:resource="http://nuclex.org/ontology/nuclex_000811"/>
  </owl:Class>
  <owl:Class rdf:about="http://nuclex.org/ontology/nuclex_000008">
    <rdfs:label>somatostatin receptor radiopharmaceutical therapy</rdfs:label>
    <nuclex:preferred_name>somatostatin receptor radiopharmaceutical therapy</nuclex:preferred_name>
    <oio:id>nuclex:000008</oio:id>
    <nuclex:definition>A targeted radiopharmaceutical therapy that uses radiolabeled somatostatin analogs, which bind to somatostatin receptors overexpressed on certain tumor cells, such as neuroendocrine tumors.</nuclex:definition>
