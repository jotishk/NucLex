  <owl:Class rdf:about="http://nuclex.org/ontology/nuclex_000667">
    <rdfs:label>total lesion glygolysis</rdfs:label>
    <nuclex:preferred_name>total lesion glygolysis</nuclex:preferred_name>
    <oio:id>nuclex:000667</oio:id>
    <nuclex:definition>The product of the metabolic tumor volume and the mean SUV of the identified tumor regions.</nuclex:definition>
    <nuclex:synonym>TLG</nuclex:synonym>
    <nuclex:nuclex_nid>nuclex:000667</nuclex:nuclex_nid>
