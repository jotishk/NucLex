    <rdfs:subClassOf rdf:resource="http://nuclex.org/ontology/nuclex_001170"/>
  </owl:Class>
  <owl:Class rdf:about="http://nuclex.org/ontology/nuclex_000293">
    <rdfs:label>time-activity curve fitting method</rdfs:label>
    <nuclex:preferred_name>time-activity curve fitting method</nuclex:preferred_name>
    <oio:id>nuclex:000293</oio:id>
    <nuclex:definition>A method utilized to approximate the continuous kinetic behavior of a radiopharmaceutical within a target region by applying a mathematical function or numerical approximation to a discrete set of sequential activity measurements.</nuclex:definition>
    <rdfs:comment>This branch may fit better under image analysis section.</rdfs:comment>
    <nuclex:synonym>TAC fitting method</nuclex:synonym>
    <nuclex:nuclex_nid>nuclex:000293</nuclex:nuclex_nid>
    <rdfs:subClassOf rdf:resource="http://nuclex.org/ontology/nuclex_000268"/>
  </owl:Class>
