  <owl:Class rdf:about="http://nuclex.org/ontology/nuclex_000814">
    <rdfs:label>American College of Radiology-approved positron emission tomography phantom</rdfs:label>
    <nuclex:preferred_name>American College of Radiology-approved positron emission tomography phantom</nuclex:preferred_name>
    <oio:id>nuclex:000814</oio:id>
    <nuclex:definition>A fillable phantom composed of a flangeless Jaszczak phantom body with a rod resolution pattern paired with a specialized faceplate containing an arrangement of fillable (hot) and cold cylinders of varying diameters, to assess spatial resolution, object detectability, and uniformity.</nuclex:definition>
    <nuclex:synonym>ACR phantom</nuclex:synonym>
    <nuclex:synonym>ACR-approved PET phantom</nuclex:synonym>
    <nuclex:synonym>ACR PET phantom</nuclex:synonym>
    <nuclex:synonym>Jaszczak deluxe ECT phantom with PET faceplate</nuclex:synonym>
    <nuclex:synonym>Data Spectrum deluxe phantom with PET faceplate</nuclex:synonym>
    <nuclex:synonym>flangeless Esser PET phantom</nuclex:synonym>
    <nuclex:synonym>Jaszczak deluxe phantom with PET faceplate</nuclex:synonym>
    <nuclex:nuclex_nid>nuclex:000814</nuclex:nuclex_nid>
    <rdfs:subClassOf rdf:resource="http://nuclex.org/ontology/nuclex_000813"/>
  </owl:Class>
