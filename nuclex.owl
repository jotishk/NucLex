    <nuclex:preferred_name>numerical time-integrated activity calculation method</nuclex:preferred_name>
    <oio:id>nuclex:000290</oio:id>
    <nuclex:definition>A time-integrated activity calculation method that estimates total disintegrations by applying discrete mathematical integration techniques directly to a series of sequential activity measurements.</nuclex:definition>
    <nuclex:synonym>numerical TIAC calculation</nuclex:synonym>
    <nuclex:nuclex_nid>nuclex:000290</nuclex:nuclex_nid>
