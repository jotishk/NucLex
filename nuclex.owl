    <rdfs:label>alpha-emitting radiopharmaceutical</rdfs:label>
    <nuclex:preferred_name>alpha-emitting radiopharmaceutical</nuclex:preferred_name>
    <oio:id>nuclex:000543</oio:id>
    <nuclex:definition>A therapeutic radiopharmaceutical that delivers its cytotoxic effect through the emission of high linear energy transfer alpha particles.</nuclex:definition>
    <rdfs:comment>Decided to keep the term since it is important, but to structure based on indication rather than on radioisotope emission.</rdfs:comment>
    <nuclex:synonym>alpha particle emitter</nuclex:synonym>
    <nuclex:synonym>alpha therapy agent</nuclex:synonym>
    <nuclex:synonym>targeted alpha therapy agent</nuclex:synonym>
