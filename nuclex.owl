  <owl:Class rdf:about="http://nuclex.org/ontology/nuclex_000054">
    <rdfs:label>surveillance positron emission tomography scan</rdfs:label>
    <nuclex:preferred_name>surveillance positron emission tomography scan</nuclex:preferred_name>
    <oio:id>nuclex:000054</oio:id>
    <nuclex:definition>A positron emission tomography scan performed in patients with a prior history of cancer to monitor for potential disease recurrence or progression, often at scheduled intervals.</nuclex:definition>
    <nuclex:synonym>surveillance PET scan</nuclex:synonym>
    <nuclex:synonym>surveillance PET study</nuclex:synonym>
    <nuclex:synonym>surveillance PET exam</nuclex:synonym>
    <nuclex:synonym>monitoring PET scan</nuclex:synonym>
    <nuclex:synonym>monitoring PET study</nuclex:synonym>
    <nuclex:synonym>monitoring PET exam</nuclex:synonym>
    <nuclex:synonym>follow-up PET scan</nuclex:synonym>
    <nuclex:synonym>follow-up PET exam</nuclex:synonym>
    <nuclex:synonym>follow-up PET study</nuclex:synonym>
    <nuclex:nuclex_nid>nuclex:000054</nuclex:nuclex_nid>
    <rdfs:subClassOf rdf:resource="http://nuclex.org/ontology/nuclex_000048"/>
  </owl:Class>
