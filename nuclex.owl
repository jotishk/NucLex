    <nuclex:nuclex_nid>nuclex:001075</nuclex:nuclex_nid>
    <rdfs:subClassOf rdf:resource="http://nuclex.org/ontology/nuclex_001066"/>
  </owl:Class>
  <owl:Class rdf:about="http://nuclex.org/ontology/nuclex_000110">
    <rdfs:label>rest myocardial pefusion scan</rdfs:label>
    <nuclex:preferred_name>rest myocardial pefusion scan</nuclex:preferred_name>
    <oio:id>nuclex:000110</oio:id>
    <nuclex:definition>A diagnostic study where a radiopharmaceutical is injected while the patient is at rest (i.e., not exercising) to visualize blood flow to the heart muscle, often serving as a baseline comparator for a stress myocardial perfusion scan.</nuclex:definition>
    <nuclex:synonym>rest MPI</nuclex:synonym>
    <nuclex:synonym>cardiac rest scan</nuclex:synonym>
    <nuclex:synonym>rest myocardial perfusion imaging</nuclex:synonym>
    <nuclex:nuclex_nid>nuclex:000110</nuclex:nuclex_nid>
    <nuclex:playbook_rpid>RPID5352, RPID6319</nuclex:playbook_rpid>
    <rdfs:subClassOf rdf:resource="http://nuclex.org/ontology/nuclex_000102"/>
  </owl:Class>
  <owl:Class rdf:about="http://nuclex.org/ontology/nuclex_000168">
    <rdfs:label>tagged red blood cell liver scan</rdfs:label>
    <nuclex:preferred_name>tagged red blood cell liver scan</nuclex:preferred_name>
    <oio:id>nuclex:000168</oio:id>
    <nuclex:definition>A nuclear medicine imaging procedure utilizing autologous red blood cells radiolabeled with Tc-99m to differentiate a hepatic hemangioma from other focal liver lesions.</nuclex:definition>
    <nuclex:synonym>RBC liver scan</nuclex:synonym>
    <nuclex:synonym>liver scan</nuclex:synonym>
    <nuclex:synonym>hepatic hemangioma scan</nuclex:synonym>
    <nuclex:synonym>tagged RBC liver scan</nuclex:synonym>
    <nuclex:synonym>tagged RBC scan</nuclex:synonym>
    <nuclex:synonym>RBC SPECT scan</nuclex:synonym>
    <nuclex:synonym>liver SPECT scan</nuclex:synonym>
    <nuclex:synonym>hepatic hemangioma SPECT scan</nuclex:synonym>
    <nuclex:synonym>tagged RBC liver SPECT scan</nuclex:synonym>
    <nuclex:synonym>tagged RBC SPECT scan</nuclex:synonym>
    <nuclex:nuclex_nid>nuclex:000168</nuclex:nuclex_nid>
    <nuclex:playbook_rpid>RPID5205, RPID6191</nuclex:playbook_rpid>
    <rdfs:subClassOf rdf:resource="http://nuclex.org/ontology/nuclex_000046"/>
  </owl:Class>
  <owl:Class rdf:about="http://nuclex.org/ontology/nuclex_000291">
    <rdfs:label>trapezoidal time-integrated activity calculation method</rdfs:label>
    <nuclex:preferred_name>trapezoidal time-integrated activity calculation method</nuclex:preferred_name>
    <oio:id>nuclex:000291</oio:id>
    <nuclex:definition>A method that estimates the time-integrated activity by calculating the sum of the areas of geometric trapezoids mathematically formed between sequential, discrete measurement points.</nuclex:definition>
    <nuclex:synonym>trapezoidal method</nuclex:synonym>
    <nuclex:synonym>trapezoidal fitting method</nuclex:synonym>
    <nuclex:synonym>trapezoidal approach</nuclex:synonym>
    <nuclex:nuclex_nid>nuclex:000291</nuclex:nuclex_nid>
    <rdfs:subClassOf rdf:resource="http://nuclex.org/ontology/nuclex_000290"/>
  </owl:Class>
  <owl:Class rdf:about="http://nuclex.org/ontology/nuclex_000086">
