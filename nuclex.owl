    <oio:id>nuclex:000819</oio:id>
    <nuclex:definition>A standardized fillable body-shaped phantom specified by NEMA and the IEC, typically containing a simulated background compartment, a lung insert, and several fillable spheres, used to evaluate SPECT image quality.</nuclex:definition>
    <nuclex:synonym>NEMA IEC NM body phantom</nuclex:synonym>
    <nuclex:synonym>NEMA IEC SPECT body phantom</nuclex:synonym>
    <nuclex:synonym>NEMA NM image quality phantom</nuclex:synonym>
    <nuclex:synonym>NEMA SPECT image quality phantom</nuclex:synonym>
    <nuclex:synonym>NEMA SPECT phantom</nuclex:synonym>
    <nuclex:nuclex_nid>nuclex:000819</nuclex:nuclex_nid>
