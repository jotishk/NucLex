  <owl:Class rdf:about="http://nuclex.org/ontology/nuclex_000200">
    <rdfs:label>population-level radiopharmaceutical dosimetry</rdfs:label>
    <nuclex:preferred_name>population-level radiopharmaceutical dosimetry</nuclex:preferred_name>
    <oio:id>nuclex:000200</oio:id>
    <nuclex:definition>A dosimetry process that uses standardized biokinetic models and reference computational phantoms to calculates absorbed doses to organs and tissues following the administration of unsealed radioactive materials.</nuclex:definition>
    <nuclex:synonym>population dosimetry</nuclex:synonym>
    <nuclex:nuclex_nid>nuclex:000200</nuclex:nuclex_nid>
    <rdfs:subClassOf rdf:resource="http://nuclex.org/ontology/nuclex_000199"/>
  </owl:Class>
  <owl:Class rdf:about="http://nuclex.org/ontology/nuclex_001206">
    <rdfs:label>ultra-high energy collimator rating</rdfs:label>
