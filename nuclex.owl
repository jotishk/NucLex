    <rdfs:subClassOf rdf:resource="http://nuclex.org/ontology/nuclex_000537"/>
  </owl:Class>
  <owl:Class rdf:about="http://nuclex.org/ontology/nuclex_000620">
    <rdfs:label>Deauville five-point scale</rdfs:label>
    <nuclex:preferred_name>Deauville five-point scale</nuclex:preferred_name>
    <oio:id>nuclex:000620</oio:id>
    <nuclex:definition>A 5-point visual scoring system used to interpret FDG-PET/CT scans in lymphoma. It standardizes response assessment by comparing the metabolic activity (FDG PET uptake) in a tumor to the activity in reference points, specifically the mediastinal blood pool and the liver.</nuclex:definition>
    <nuclex:synonym>5-point scale</nuclex:synonym>
    <nuclex:synonym>five-point scale</nuclex:synonym>
    <nuclex:synonym>Deauville scale</nuclex:synonym>
    <nuclex:synonym>Deauville scoring</nuclex:synonym>
    <nuclex:synonym>Deauville 5-point scale</nuclex:synonym>
    <nuclex:synonym>Deauville score</nuclex:synonym>
    <nuclex:nuclex_nid>nuclex:000620</nuclex:nuclex_nid>
    <rdfs:subClassOf rdf:resource="http://nuclex.org/ontology/nuclex_000619"/>
  </owl:Class>
  <owl:Class rdf:about="http://nuclex.org/ontology/nuclex_001075">
    <rdfs:label>randoms correction method</rdfs:label>
    <nuclex:preferred_name>randoms correction method</nuclex:preferred_name>
    <oio:id>nuclex:001075</oio:id>
