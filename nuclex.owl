    <nuclex:synonym>Iodine 131 meta-iodobenzylguanidine</nuclex:synonym>
    <nuclex:synonym>131I-MIBG</nuclex:synonym>
    <nuclex:synonym>131I-iobenguane</nuclex:synonym>
    <nuclex:synonym>Iodine-131 MIBG</nuclex:synonym>
    <nuclex:synonym>iobenguane I 131</nuclex:synonym>
