  <owl:Class rdf:about="http://nuclex.org/ontology/nuclex_000157">
    <rdfs:label>colon transit study</rdfs:label>
    <nuclex:preferred_name>colon transit study</nuclex:preferred_name>
    <oio:id>nuclex:000157</oio:id>
    <nuclex:definition>A colon transit study is a nuclear medicine functional imaging procedure in which orally administered radiolabeled markers are tracked via serial gamma‑camera or scintillation detector measurements to quantify the rate and pattern of tracer passage through the colon.</nuclex:definition>
