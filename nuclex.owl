    <rdfs:subClassOf rdf:resource="http://nuclex.org/ontology/nuclex_000643"/>
  </owl:Class>
  <owl:Class rdf:about="http://nuclex.org/ontology/nuclex_000059">
    <rdfs:label>bremsstrahlung scan</rdfs:label>
    <nuclex:preferred_name>bremsstrahlung scan</nuclex:preferred_name>
    <oio:id>nuclex:000059</oio:id>
    <nuclex:definition>A nuclear medicine imaging technique that detects the secondary "braking radiation" (photons) produced when high-energy beta particles (emitted by a therapeutic radiopharmaceutical) interact with tissue</nuclex:definition>
    <nuclex:synonym>bremsstrahlung SPECT</nuclex:synonym>
    <nuclex:synonym>BRS SPECT</nuclex:synonym>
    <nuclex:synonym>BRS scan</nuclex:synonym>
    <nuclex:nuclex_nid>nuclex:000059</nuclex:nuclex_nid>
    <rdfs:subClassOf rdf:resource="http://nuclex.org/ontology/nuclex_000047"/>
  </owl:Class>
  <owl:Class rdf:about="http://nuclex.org/ontology/nuclex_000510">
    <rdfs:label>somatostatin receptor targeted beta-emitting radiopharmaceutical</rdfs:label>
    <nuclex:preferred_name>somatostatin receptor targeted beta-emitting radiopharmaceutical</nuclex:preferred_name>
    <oio:id>nuclex:000510</oio:id>
    <nuclex:definition>A therapeutic radiopharmaceutical that targets somatostatin receptors and delivers its cytotoxic effect through the emission of high-energy beta particles.</nuclex:definition>
    <nuclex:synonym>SSTR beta-emitter</nuclex:synonym>
    <nuclex:synonym>beta-emitting SSTR PRRT</nuclex:synonym>
    <nuclex:synonym>β-emitting SSTR radiopharmaceutical</nuclex:synonym>
    <nuclex:nuclex_nid>nuclex:000510</nuclex:nuclex_nid>
    <rdfs:subClassOf rdf:resource="http://nuclex.org/ontology/nuclex_000509"/>
  </owl:Class>
