  </owl:Class>
  <owl:Class rdf:about="http://nuclex.org/ontology/nuclex_000142">
    <rdfs:label>dynamic renal scan</rdfs:label>
    <nuclex:preferred_name>dynamic renal scan</nuclex:preferred_name>
    <oio:id>nuclex:000142</oio:id>
    <nuclex:definition>A nuclear medicine imaging procedure that continuously records the transit of a radiopharmaceutical through the kidneys, ureters, and bladder over time to evaluate renal perfusion, function, and excretion.</nuclex:definition>
    <nuclex:synonym>renogram</nuclex:synonym>
    <nuclex:synonym>renography</nuclex:synonym>
    <nuclex:nuclex_nid>nuclex:000142</nuclex:nuclex_nid>
    <nuclex:playbook_rpid>RPID6187</nuclex:playbook_rpid>
