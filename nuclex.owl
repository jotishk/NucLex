  <owl:Class rdf:about="http://nuclex.org/ontology/nuclex_000107">
    <rdfs:label>stress myocardial perfusion scan</rdfs:label>
    <nuclex:preferred_name>stress myocardial perfusion scan</nuclex:preferred_name>
    <oio:id>nuclex:000107</oio:id>
    <nuclex:definition>A diagnostic study where a radiopharmaceutical is injected while the patient is under physiological stress, either through exercises or a pharmacological agent, to visualize blood flow to the heart muscle.</nuclex:definition>
    <nuclex:synonym>nuclear stress test</nuclex:synonym>
    <nuclex:synonym>stress MPI</nuclex:synonym>
    <nuclex:synonym>cardiac stress scan</nuclex:synonym>
    <nuclex:synonym>stress myocardial perfusion imaging</nuclex:synonym>
    <nuclex:synonym>stress myocardial perfusion study</nuclex:synonym>
    <nuclex:nuclex_nid>nuclex:000107</nuclex:nuclex_nid>
    <nuclex:playbook_rpid>RPID5352, RPID6319</nuclex:playbook_rpid>
    <rdfs:subClassOf rdf:resource="http://nuclex.org/ontology/nuclex_000102"/>
  </owl:Class>
  <owl:Class rdf:about="http://nuclex.org/ontology/nuclex_000282">
    <rdfs:label>kernel-based absorbed dose calculation</rdfs:label>
    <nuclex:preferred_name>kernel-based absorbed dose calculation</nuclex:preferred_name>
    <oio:id>nuclex:000282</oio:id>
    <nuclex:definition>A voxel-based absorbed dose calculation that utilizes pre-calculated spatial energy deposition patterns to determine the dose contribution from a source to surrounding voxels.</nuclex:definition>
    <nuclex:synonym>VSV dosimetry</nuclex:synonym>
    <nuclex:synonym>kernel dosimetry</nuclex:synonym>
    <nuclex:nuclex_nid>nuclex:000282</nuclex:nuclex_nid>
    <rdfs:subClassOf rdf:resource="http://nuclex.org/ontology/nuclex_000281"/>
  </owl:Class>
  <owl:Class rdf:about="http://nuclex.org/ontology/nuclex_001185">
    <rdfs:label>nuclear imaging device property</rdfs:label>
    <nuclex:preferred_name>nuclear imaging device property</nuclex:preferred_name>
    <oio:id>nuclex:001185</oio:id>
